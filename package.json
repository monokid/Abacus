{
  "name": "abacus",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A calm Dutch yearly household-budget desktop app.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:input": "node tests/smoke/input-smoke.mjs",
    "verify": "npm run typecheck && npm test && npm run build",
    "package:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-test-package.ps1"
  },
  "dependencies": {
    "@lucide/svelte": "^1.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "svelte": "^5.16.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/node": "^24.0.15",
    "playwright-core": "^1.61.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
